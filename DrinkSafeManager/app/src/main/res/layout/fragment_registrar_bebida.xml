<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/azul_oscuro"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Registrar bebida"
            app:titleTextColor="@color/blanco"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/blanco" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Formulario de registro -->
            <LinearLayout
                android:id="@+id/layout_formulario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Instrucción -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/azul_tecnologico_suave"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_info"
                            android:contentDescription="Información"
                            android:tint="@color/azul_tecnologico" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Completa el formulario y presiona 'Registrar bebida'. El sistema leerá los sensores de la Raspberry Pi automáticamente."
                            android:textSize="13sp"
                            android:textColor="@color/azul_oscuro"
                            android:layout_marginStart="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Campo: Nombre -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_nombre"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre de la bebida"
                    app:startIconDrawable="@drawable/ic_label"
                    app:startIconTint="@color/azul_tecnologico"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Marca -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_marca"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Marca o fabricante"
                    app:startIconDrawable="@drawable/ic_brand"
                    app:startIconTint="@color/azul_tecnologico"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_marca"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Tipo de bebida: ChipGroup -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo de bebida"
                    android:textSize="14sp"
                    android:textColor="@color/texto_primario"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_tipo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_vodka"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vodka"
                        app:chipIcon="@drawable/ic_vodka"
                        app:chipIconTint="@color/azul_tecnologico" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_tequila"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tequila blanco"
                        app:chipIcon="@drawable/ic_tequila"
                        app:chipIconTint="@color/verde_exito" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_otro"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Otro"
                        app:chipIcon="@drawable/ic_drink_generic" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Campo: Notas (opcional) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_notas"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Notas adicionales (opcional)"
                    app:startIconDrawable="@drawable/ic_notes"
                    app:startIconTint="@color/azul_tecnologico"
                    android:layout_marginBottom="24dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_notas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:maxLines="4"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botón principal de registro -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_registrar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Registrar bebida"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/azul_oscuro"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_sensor"
                    app:iconGravity="textStart"
                    app:iconTint="@color/blanco" />

            </LinearLayout>

            <!-- Panel de sensores activos (visible durante el análisis) -->
            <LinearLayout
                android:id="@+id/layout_sensores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <!-- Icono animado del sensor -->
                <ImageView
                    android:id="@+id/iv_sensor_icon"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_drinksafe_logo"
                    android:contentDescription="Sensor activo"
                    android:layout_marginBottom="24dp" />

                <!-- Estado del sensor -->
                <TextView
                    android:id="@+id/tv_estado_sensor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Leyendo sensores..."
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/azul_oscuro"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_descripcion_sensor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="El sensor AS7262 está analizando la muestra"
                    android:textSize="14sp"
                    android:textColor="@color/texto_secundario"
                    android:gravity="center"
                    android:layout_marginBottom="32dp" />

                <!-- Indicadores de sensores -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="32dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/azul_tecnologico_suave"
                        android:layout_marginEnd="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="AS7262" android:textSize="11sp" android:textColor="@color/azul_tecnologico"
                                android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Espectral" android:textSize="10sp" android:textColor="@color/texto_secundario" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/verde_suave"
                        android:layout_marginHorizontal="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Conduct." android:textSize="11sp" android:textColor="@color/verde_exito"
                                android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="µS/cm" android:textSize="10sp" android:textColor="@color/texto_secundario" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/azul_tecnologico_suave"
                        android:layout_marginStart="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Temp." android:textSize="11sp" android:textColor="@color/azul_tecnologico"
                                android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="°C" android:textSize="10sp" android:textColor="@color/texto_secundario" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Progress indicator -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_sensores"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/azul_tecnologico"
                    app:trackColor="@color/azul_tecnologico_suave"
                    app:indicatorSize="64dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
