<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_claro">

    <!-- AppBar con título -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/azul_oscuro"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DrinkSafe Manager"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanco" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Panel de administración"
                    android:textSize="13sp"
                    android:textColor="#80FFFFFF" />
            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Saludo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado del sistema"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <!-- Card de estado de conexión -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_estado_conexion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/azul_oscuro"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/azul_tecnologico"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iv_estado_conexion"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_connection_checking"
                        android:contentDescription="Estado de conexión" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Raspberry Pi 4"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/blanco" />

                        <TextView
                            android:id="@+id/tv_estado_conexion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verificando..."
                            android:textSize="13sp"
                            android:textColor="@color/azul_tecnologico"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tv_total_bebidas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 bebidas registradas"
                            android:textSize="12sp"
                            android:textColor="#60FFFFFF"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_refresh_conexion"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_refresh"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Actualizar conexión"
                        android:tint="@color/azul_tecnologico" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sección: Acciones principales -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acciones rápidas"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Card: Registrar nueva bebida -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_registrar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/blanco"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_icon_primary"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_add_drink"
                            android:contentDescription="Agregar bebida"
                            android:tint="@color/blanco" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Registrar nueva bebida"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/azul_oscuro" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Captura datos de referencia desde sensores"
                            android:textSize="13sp"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="Ir"
                        android:tint="@color/texto_secundario" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Ver base de datos -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_base_datos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/blanco"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_icon_secondary"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_database"
                            android:contentDescription="Base de datos"
                            android:tint="@color/blanco" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Base de datos de bebidas"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/azul_oscuro" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Consulta y gestiona las referencias"
                            android:textSize="13sp"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="Ir"
                        android:tint="@color/texto_secundario" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Configuración -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_configuracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/blanco"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_icon_tertiary"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/iv_config"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_settings"
                            android:contentDescription="Configuración"
                            android:tint="@color/blanco" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Configuración del sistema"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/azul_oscuro" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IP, sensores y parámetros del dispositivo"
                            android:textSize="13sp"
                            android:textColor="@color/texto_secundario"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="Ir"
                        android:tint="@color/texto_secundario" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DrinkSafe · Sistema de detección de alcohol adulterado"
                android:textSize="11sp"
                android:textColor="@color/texto_secundario"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
